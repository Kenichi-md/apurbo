<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>apurbo Games - baler car game</title>
    <style>
        /* মূল থিম ও ডিজাইন */
        :root {
            --bg-color: #f0f2f5;
            --text-color: #333;
            --panel-bg: #ffffff;
            --road-bg: #333333;
        }

        [data-theme="dark"] {
            --bg-color: #1a1a1a;
            --text-color: #f0f2f5;
            --panel-bg: #2d2d2d;
            --road-bg: #111111;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            user-select: none;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            transition: background-color 0.3s, color 0.3s;
            display: block;
            text-align: center;
            padding: 20px;
        }

        header {
            margin-bottom: 15px;
        }

        h1 {
            font-size: 24px;
            color: #e74c3c;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
            margin-bottom: 5px;
        }

        /* কন্ট্রোল প্যানেল */
        .controls-panel {
            background-color: var(--panel-bg);
            padding: 10px 20px;
            border-radius: 8px;
            display: inline-block;
            margin-bottom: 15px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        button {
            padding: 8px 15px;
            margin: 5px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            background-color: #3498db;
            color: white;
            transition: background 0.2s;
        }

        button:hover {
            background-color: #2980b9;
        }

        .score-board {
            font-size: 18px;
            font-weight: bold;
            margin-top: 5px;
        }

        /* গেম এরিয়া (রাস্তা) */
        #gameArea {
            width: 320px;
            height: 480px;
            background-color: var(--road-bg);
            margin: 0 auto;
            position: relative;
            overflow: hidden;
            border: 4px solid #fff;
            border-radius: 10px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }

        /* রাস্তার সাদা ড্যাশ লাইন */
        .road-line {
            width: 8px;
            height: 40px;
            background-color: #fff;
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
        }

        /* প্লেয়ার ও শত্রু গাড়ি */
        .car {
            width: 40px;
            height: 70px;
            position: absolute;
            border-radius: 5px;
        }

        #playerCar {
            background-color: #e74c3c; /* লাল রঙের খেলোয়াড়ের গাড়ি */
            bottom: 20px;
            left: 140px;
            transition: left 0.05s linear;
        }

        /* গাড়ির চাকা ও জানালার ডিজাইন */
        .car::before {
            content: '';
            position: absolute;
            top: 10px; left: 5px; right: 5px; height: 12px;
            background-color: #a6d8f0;
            border-radius: 2px;
        }

        .enemy {
            background-color: #f1c40f; /* হলুদ রঙের শত্রু গাড়ি */
            top: -80px;
        }

        /* গেম ওভার স্ক্রিন */
        #gameOverScreen {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.8);
            color: white;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 10;
        }

        /* মোবাইল টাচ কন্ট্রোল বাটন */
        .mobile-controls {
            margin-top: 15px;
        }

        .touch-btn {
            width: 70px;
            height: 50px;
            font-size: 20px;
            background-color: #2ecc71;
        }

        .touch-btn:active {
            background-color: #27ae60;
        }
    </style>
</head>
<body>

    <header>
        <h1>apurbor babar  Games</h1>
        <div class="score-board">স্কোর: <span id="score">0</span></div>
    </header>

    <div class="controls-panel">
        <button id="themeToggle">ডার্ক মোড: অফ</button>
        <button id="musicToggle">মিউজিক: অন</button>
        <button id="startBtn" onclick="startGame()">গেম শুরু করুন</button>
    </div>

    <div id="gameArea">
        <div id="gameOverScreen">
            <h2 style="font-size: 28px; margin-bottom: 10px; color: #ff4757;">গেম ওভার!</h2>
            <p style="font-size: 18px; margin-bottom: 20px;">আপনার মোট স্কোর: <span id="finalScore">0</span></p>
            <button onclick="startGame()" style="background-color: #2ecc71;">আবার খেলুন</button>
        </div>
        <div id="playerCar" class="car"></div>
    </div>

    <div class="mobile-controls">
        <button class="touch-btn" id="leftBtn">◀</button>
        <button class="touch-btn" id="rightBtn">▶</button>
    </div>

    <script>
        const gameArea = document.getElementById('gameArea');
        const playerCar = document.getElementById('playerCar');
        const scoreDisplay = document.getElementById('score');
        const gameOverScreen = document.getElementById('gameOverScreen');
        const finalScoreDisplay = document.getElementById('finalScore');
        const themeToggle = document.getElementById('themeToggle');
        const musicToggle = document.getElementById('musicToggle');

        let isPlaying = false;
        let score = 0;
        let playerX = 140; // প্রারম্ভিক অবস্থান
        let roadLines = [];
        let enemies = [];
        let animationFrameId;
        
        // ফিচারের জন্য ডিফল্ট সেটিংস
        let isDarkMode = false;
        let isMusicOn = true;

        // অডিও কনটেক্সট (মিউজিক এর জন্য ব্রাউজার জেনারেটেড সাউন্ড)
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        
        function playSound(frequency, type, duration) {
            if (!isMusicOn) return;
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            oscillator.type = type;
            oscillator.frequency.value = frequency;
            gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            oscillator.start();
            oscillator.stop(audioCtx.currentTime + duration);
        }

        // রাস্তার ব্যাকগ্রাউন্ড লাইন তৈরি
        function createRoadLines() {
            for (let i = 0; i < 5; i++) {
                let line = document.createElement('div');
                line.classList.add('road-line');
                line.style.top = (i * 100) + 'px';
                gameArea.appendChild(line);
                roadLines.push(line);
            }
        }
        createRoadLines();

        // শত্রু গাড়ি তৈরি
        function createEnemy() {
            if (enemies.length < 2) {
                let enemy = document.createElement('div');
                enemy.classList.add('car', 'enemy');
                enemy.style.left = Math.floor(Math.random() * 260) + 'px';
                enemy.style.top = '-80px';
                gameArea.appendChild(enemy);
                enemies.push(enemy);
            }
        }

        // গেম শুরু করার মূল ফাংশন
        function startGame() {
            // পূর্বের শত্রু গাড়ি ও স্ক্রিন পরিষ্কার করা
            enemies.forEach(enemy => enemy.remove());
            enemies = [];
            gameOverScreen.style.display = 'none';
            score = 0;
            playerX = 140;
            playerCar.style.left = playerX + 'px';
            scoreDisplay.innerText = score;
            isPlaying = true;
            
            // বিফ সাউন্ড গেম শুরুর সংকেত হিসেবে
            playSound(440, 'square', 0.2);
            
            cancelAnimationFrame(animationFrameId);
            animationFrameId = requestAnimationFrame(gameLoop);
        }

        // গেমের লুপ (ক্রমাগত অ্যানিমেশন)
        function gameLoop() {
            if (!isPlaying) return;

            // রাস্তার লাইন চালানো (চলন্ত রাস্তার অনুভূতি)
            roadLines.forEach(line => {
                let top = parseInt(line.style.top);
                top += 5;
                if (top >= 480) top = -40;
                line.style.top = top + 'px';
            });

            // শত্রু গাড়ি চালানো ও তৈরি করা
            if (Math.random() < 0.02) createEnemy();

            enemies.forEach((enemy, index) => {
                let top = parseInt(enemy.style.top);
                top += 6; // শত্রু গাড়ির গতিবেগ
                enemy.style.top = top + 'px';

                // স্ক্রিন পার হয়ে গেলে স্কোর বৃদ্ধি ও পুনরায় উপরে পাঠানো
                if (top > 480) {
                    score += 10;
                    scoreDisplay.innerText = score;
                    playSound(600, 'sine', 0.05); // পয়েন্ট পাওয়ার সাউন্ড
                    enemy.remove();
                    enemies.splice(index, 1);
                }

                // সংঘর্ষ (Collision) চেক করা
                if (isColliding(playerCar, enemy)) {
                    endGame();
                }
            });

            animationFrameId = requestAnimationFrame(gameLoop);
        }

        // সংঘর্ষ নির্ণয় পদ্ধতি
        function isColliding(a, b) {
            let aRect = a.getBoundingClientRect();
            let bRect = b.getBoundingClientRect();

            return !(
                aRect.bottom < bRect.top ||
                aRect.top > bRect.bottom ||
                aRect.right < bRect.left ||
                aRect.left > bRect.right
            );
        }

        // গেম সমাপ্তি
        function endGame() {
            isPlaying = false;
            cancelAnimationFrame(animationFrameId);
            playSound(150, 'sawtooth', 0.5); // গেম ওভারের বাজনা
            finalScoreDisplay.innerText = score;
            gameOverScreen.style.display = 'flex';
        }

        // কিবোর্ড কন্ট্রোল (কম্পিউটার ব্যবহারকারীদের জন্য)
        window.addEventListener('keydown', (e) => {
            if (!isPlaying) return;
            if (e.key === 'ArrowLeft' && playerX > 10) {
                playerX -= 25;
            }
            if (e.key === 'ArrowRight' && playerX < 270) {
                playerX += 25;
            }
            playerCar.style.left = playerX + 'px';
        });

        // অন-স্ক্রিন বাটন কন্ট্রোল (মোবাইল ব্যবহারকারীদের জন্য)
        document.getElementById('leftBtn').addEventListener('click', () => {
            if (isPlaying && playerX > 10) {
                playerX -= 25;
                playerCar.style.left = playerX + 'px';
            }
        });

        document.getElementById('rightBtn').addEventListener('click', () => {
            if (isPlaying && playerX < 270) {
                playerX += 25;
                playerCar.style.left = playerX + 'px';
            }
        });

        // ডার্ক মোড অন/অফ লজিক
        themeToggle.addEventListener('click', () => {
            isDarkMode = !isDarkMode;
            if (isDarkMode) {
                document.body.setAttribute('data-theme', 'dark');
                themeToggle.innerText = 'ডার্ক মোড: অন';
            } else {
                document.body.removeAttribute('data-theme');
                themeToggle.innerText = 'ডার্ক মোড: অফ';
            }
        });

        // মিউজিক অন/অফ লজিক
        musicToggle.addEventListener('click', () => {
            isMusicOn = !isMusicOn;
            if (isMusicOn) {
                musicToggle.innerText = 'মিউজিক: অন';
            } else {
                musicToggle.innerText = 'মিউজিক: অফ';
            }
        });
    </script>
</body>
</html>
